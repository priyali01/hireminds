NODE_ENV=development
PORT=3001

# MongoDB — get a free cluster at mongodb.com/atlas
MONGODB_URI=mongodb://127.0.0.1:27017/hireminds

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_THIS
JWT_REFRESH_SECRET=GENERATE_THIS_DIFFERENT

# AI — get from aistudio.google.com
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# --- Optional (Phase 2+) ---
REDIS_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESEND_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
